<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="1">
    <title>Velotype</title>
    <welcome>Velotype is a block-based Markdown editor built with Rust and GPUI.</welcome>
    <options customize="never" require-scripts="true" rootVolumeOnly="true"/>
    <volume-check>
        <allowed-os-versions>
            <os-version min="10.15"/>
        </allowed-os-versions>
    </volume-check>
    <choices-outline>
        <line choice="default">
            <line choice="Velotype"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="Velotype" title="Install Velotype" description="Install Velotype to /Applications">
        <pkg-ref id="com.manyougz.Velotype"/>
    </choice>
    <pkg-ref id="com.manyougz.Velotype" version="0.5.0" onConclusion="none">#Velotype-component.pkg</pkg-ref>
</installer-gui-script>
